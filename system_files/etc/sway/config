# Ported from ~/.dotfiles/home/linux/sway.nix (groove palette).
# Overrides: ~/.config/sway/config.d/*.conf or /etc/sway/config.d/*.conf
# (drop-in dir included at end). Wayland env vars live in /etc/environment.

### Colors (groove palette — see modules/common/colors/groove.nix) ###
set $bg-color            #282828
set $inactive-bg-color   #222222
set $text-color          #ffffff
set $inactive-text-color #ffffff
set $urgent-bg-color     #ea6962

### Window colors ###
#                       border              background         text                 indicator
client.focused          $bg-color           $bg-color          $text-color          $bg-color
client.unfocused        $inactive-bg-color  $inactive-bg-color $inactive-text-color $inactive-bg-color
client.focused_inactive $inactive-bg-color  $inactive-bg-color $inactive-text-color $inactive-bg-color
client.urgent           $urgent-bg-color    $urgent-bg-color   $text-color          $urgent-bg-color

### Fonts / borders / behavior ###
font pango:JetBrainsMono Nerd Font, Cascadia Mono NF 10

# pixel borders => no titlebar drawn
default_border          pixel 2
default_floating_border pixel 2

gaps inner 4
gaps outer 4
smart_gaps on
smart_borders on

focus_follows_mouse        no
focus_on_window_activation focus

### Window rules ###
# Inhibit idle if any window is fullscreen
for_window [app_id=".*"] inhibit_idle fullscreen
# nix-rebuild floating window kept for parity even though the helper
# itself is gone; harmless if no window ever matches.
for_window [title="nix-rebuild"] floating enable, resize set 800 400

### Workspace assignments ###
assign [app_id="Kitty"]       workspace q
assign [app_id="Thunderbird"] workspace e
assign [app_id="signal"]      workspace s
assign [app_id="vesktop"]     workspace s
assign [class="obsidian"]     workspace d
assign [class="Cider"]        workspace z

### Lid switch ###
# Disable laptop display when the lid is closed (kept enabled when open)
bindswitch --reload --locked lid:on  output eDP-1 disable
bindswitch --reload --locked lid:off output eDP-1 enable

### Autostart ###
exec_always --no-startup-id /usr/bin/autotiling-rs

exec swayidle -w \
    timeout 300 'swaylock -f' \
    timeout 600 'swaymsg "output * power off"' \
    resume 'swaymsg "output * power on"' \
    before-sleep 'swaylock -f'

exec dbus-update-activation-environment --systemd DISPLAY WAYLAND_DISPLAY \
    SWAYSOCK XDG_CURRENT_DESKTOP=sway
exec gnome-keyring-daemon --start --components=secrets,ssh,pkcs11

# Hyprland polkit auth agent (handles GUI password prompts for pkexec etc.) +
# kitty startup session. Started via systemctl --user so the unit shipped by
# the hyprpolkitagent package owns lifecycle/env, not sway.
exec systemctl --user start hyprpolkitagent.service
exec kitty --session startup.session

# First-boot welcome: pops a kitty window the first time the user logs in
# (idempotent — setup.sh exits immediately once ~/.config/blueberry/firstboot.done
# exists). Replaces the systemd user oneshot, which had no TTY and so
# couldn't drive `gum confirm` prompts.
exec sh -c 'test -e "$HOME/.config/blueberry/firstboot.done" || kitty --hold -e /usr/share/blueberry/firstboot/setup.sh'

### Modifier keys ###
set $mod Mod1
set $sup Mod4

### Modes ###
set $mode_system "(p)oweroff, (s)uspend, (h)ibernate, (r)eboot, (l)ogout"
mode $mode_system {
    bindsym p exec swaymsg 'mode default' && systemctl poweroff
    bindsym s exec swaymsg 'mode default' && systemctl suspend-then-hibernate
    bindsym h exec swaymsg 'mode default' && systemctl hibernate
    bindsym r exec swaymsg 'mode default' && systemctl reboot
    bindsym l exec swaymsg 'mode default' && systemctl --user stop sway-session.target && systemctl --user stop graphical-session.target && swaymsg exit
    bindsym Return mode default
    bindsym Escape mode default
}
bindsym $sup+Escape mode $mode_system

### Keybindings ###
# Screenshots — inline grim/slurp (system has no sway-screenshot-* helpers).
bindsym Print          exec grim -g "$(slurp)" - | wl-copy
bindsym Shift+Print    exec grim - | wl-copy
bindsym $sup+Shift+3   exec grim - | wl-copy
bindsym $sup+Shift+4   exec grim -g "$(slurp)" - | wl-copy

# Brightness / media / volume
bindsym XF86MonBrightnessUp    exec brightnessctl set 5%+
bindsym XF86MonBrightnessDown  exec brightnessctl set 5%-

bindsym XF86AudioPlay   exec playerctl play-pause
bindsym XF86AudioPause  exec playerctl play-pause
bindsym XF86AudioPrev   exec playerctl previous
bindsym XF86AudioNext   exec playerctl next
bindsym XF86AudioStop   exec playerctl stop

bindsym XF86AudioRaiseVolume  exec pactl set-sink-volume @DEFAULT_SINK@ +5%
bindsym XF86AudioLowerVolume  exec pactl set-sink-volume @DEFAULT_SINK@ -5%
bindsym XF86AudioMute         exec pactl set-sink-mute   @DEFAULT_SINK@ toggle

# Terminal + launcher
bindsym $mod+Return         exec kitty
bindsym $sup+Return         exec kitty
bindsym $mod+Shift+Return   exec kitty --session startup.session

bindsym $mod+Shift+r        reload
bindsym $sup+d              exec rofi -show drun
bindsym $mod+Space          exec rofi -show drun
bindsym $sup+Space          exec rofi -show drun

# Focus
bindsym $mod+Left   focus left
bindsym $mod+Down   focus down
bindsym $mod+Up     focus up
bindsym $mod+Right  focus right

bindsym $mod+h  focus left
bindsym $mod+j  focus down
bindsym $mod+k  focus up
bindsym $mod+l  focus right

bindsym $sup+Tab        focus next
bindsym $sup+Shift+Tab  focus prev

# Move
bindsym $mod+Shift+Left   move left
bindsym $mod+Shift+Down   move down
bindsym $mod+Shift+Up     move up
bindsym $mod+Shift+Right  move right

bindsym $mod+Shift+h  move left
bindsym $mod+Shift+j  move down
bindsym $mod+Shift+k  move up
bindsym $mod+Shift+l  move right

# Scratchpad
bindsym $mod+Shift+m  move scratchpad
bindsym $mod+m        scratchpad show

# Layout
bindsym $mod+Shift+b      splith
bindsym $mod+Shift+v      splitv
bindsym $mod+f            fullscreen
bindsym $mod+p            focus parent
bindsym $mod+g            layout stacking
bindsym $mod+t            layout tabbed
bindsym $mod+b            layout toggle split
bindsym $mod+Shift+Space  floating toggle
bindsym $mod+y            focus mode_toggle

# Workspaces
bindsym $mod+q  workspace q
bindsym $mod+w  workspace w
bindsym $mod+e  workspace e
bindsym $mod+a  workspace a
bindsym $mod+s  workspace s
bindsym $mod+d  workspace d
bindsym $mod+z  workspace z
bindsym $mod+x  workspace x
bindsym $mod+c  workspace c

bindsym $mod+Shift+q  move container to workspace q
bindsym $mod+Shift+w  move container to workspace w
bindsym $mod+Shift+e  move container to workspace e
bindsym $mod+Shift+a  move container to workspace a
bindsym $mod+Shift+s  move container to workspace s
bindsym $mod+Shift+d  move container to workspace d
bindsym $mod+Shift+z  move container to workspace z
bindsym $mod+Shift+x  move container to workspace x
bindsym $mod+Shift+c  move container to workspace c

# App-specific shortcuts. All Flatpaks — no bare binary lands in PATH, so go
# through `flatpak run` (matches the workspace assignments above).
bindsym $mod+Control+Shift+w  exec flatpak run org.mozilla.firefox
bindsym $mod+Control+Shift+a  exec flatpak run org.mozilla.firefox "https://claude.ai"
bindsym $mod+Control+Shift+d  exec flatpak run md.obsidian.Obsidian
bindsym $mod+Control+Shift+s  exec flatpak run org.signal.Signal
bindsym $mod+Control+Shift+v  exec flatpak run dev.vencord.Vesktop

# Session
bindsym $sup+Shift+q  kill
bindsym $sup+Shift+e  exec swaynag -t warning -m 'You pressed the exit shortcut. Do you really want to exit sway? This will end your Wayland session.' -b 'Yes, exit sway' 'swaymsg exit'

### Input ###
input "type:touchpad" {
    tap enabled
    tap_button_map lrm
    middle_emulation enabled
    natural_scroll disabled
    drag_lock disabled
    scroll_factor 0.7
}

input "type:pointer" {
    accel_profile flat
    pointer_accel -0.15
}

input "*" {
    xkb_layout us
    repeat_delay 200
    repeat_rate 40
}

### Output ###
output eDP-1 {
    resolution 2880x1920@120Hz
    position 0,0
}
output DP-5 {
    resolution 3440x1440@144Hz
    position 0,0
}

### Bar ###
bar {
    position top
    swaybar_command waybar
    font pango:JetBrainsMono Nerd Font, Cascadia Mono NF 10
}

### Drop-in directory for user/system overrides ###
include /etc/sway/config.d/*.conf
