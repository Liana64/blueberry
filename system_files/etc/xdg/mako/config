# /etc/xdg/mako/config — Blueberry system mako notification config.
# Ported from ~/.dotfiles/home/linux/mako.nix.
# Format: INI (key=value), see mako(5) — https://man.archlinux.org/man/mako.5
#
# Font note: JetBrainsMono Nerd Font is preferred but Fedora F43 has no
# RPM for it; cascadia-mono-nf-fonts is shipped by the image as the
# nearest mono nerd fallback. Pango font strings cannot list multiple
# families, so we keep the JetBrainsMono name and rely on fontconfig
# substitution to fall back to Cascadia Mono NF when JetBrainsMono is
# missing. (See /etc/fonts/conf.d/ for the system fontconfig stack.)

default-timeout=3000
ignore-timeout=false
border-radius=5
font=JetBrainsMono Nerd Font 10
icons=true

# groove palette
background-color=#222222
border-color=#282828
text-color=#fbf1c7
