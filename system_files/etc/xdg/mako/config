# Ported from ~/.dotfiles/home/linux/mako.nix.
#
# Pango font strings can't list fallbacks, so keep "JetBrainsMono Nerd
# Font" and rely on fontconfig to substitute cascadia-mono-nf-fonts
# (Fedora F43 has no JetBrainsMono NF RPM).

default-timeout=3000
ignore-timeout=false
border-radius=5
font=JetBrainsMono Nerd Font 10
icons=true

# groove palette
background-color=#222222
border-color=#282828
text-color=#fbf1c7
