/* Ported from ~/.dotfiles/home/linux/rofi.nix; theme at themes/blueberry.rasi. */

configuration {
    modi:                "drun";
    show-icons:          true;
    drun-display-format: "{name}";
    display-drun:        "";
    sidebar-mode:        false;
    font:                "JetBrainsMono Nerd Font 12";
}

@theme "blueberry"
